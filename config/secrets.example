# =============================================================================
# myDKG_ID — Secrets Format Reference
# =============================================================================
# Copy this to authelia/.secrets (or a secure location of your choice)
# and replace each placeholder with a generated value.
#
# ⚠️  NEVER COMMIT THE REAL SECRETS FILE.
# This file IS safe to commit — it contains no real secrets.
# =============================================================================

# Each line is KEY=VALUE with no quotes, no spaces around '=', no trailing spaces.
# Blank lines and lines starting with '#' are ignored by the deploy script.

# ---------------------------------------------------------------------------
# JWT_SECRET — JWT signing key for identity validation / password reset
# ---------------------------------------------------------------------------
# Used by Authelia's identity_validation.reset_password.jwt_secret.
# Generate with:  openssl rand -hex 64
JWT_SECRET=replace-with-generated-value

# ---------------------------------------------------------------------------
# SESSION_SECRET — Session cookie encryption & validation key
# ---------------------------------------------------------------------------
# Used by Authelia's session.secret.
# Generate with:  openssl rand -hex 64
SESSION_SECRET=replace-with-generated-value

# ---------------------------------------------------------------------------
# STORAGE_SECRET — SQLite storage backend encryption key
# ---------------------------------------------------------------------------
# Used by Authelia's storage.encryption_key.
# Generate with:  openssl rand -hex 64
STORAGE_SECRET=replace-with-generated-value
